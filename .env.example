# MongoDB Atlas connection string.
# Get it from Atlas → Connect → Drivers → "node.js" → copy the SRV uri,
# replace <db_password> with your database user's password.
#
# Example:
# mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority&appName=handwerker-auftritt
MONGODB_URI=